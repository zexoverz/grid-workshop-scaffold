# --- Mock data endpoints (FORU eng provides these on workshop day) -----------
MOCK_TWITTER_URL=https://mock-twitter.foruai.io
MOCK_NEWS_URL=https://mock-news.foruai.io
MOCK_PRICES_URL=https://mock-prices.foruai.io
MOCK_ONCHAIN_URL=https://mock-onchain.foruai.io

# --- Agent runtime selector --------------------------------------------------
# openai = use OpenAI-compatible chat API (default; uses LLM_* below)
# codebuddy = use Tencent CodeBuddy Agent SDK (uses CODEBUDDY_* below)
AGENT_RUNTIME=openai

# --- LLM (OpenAI-compatible) -------------------------------------------------
# A shared key is issued per team/solo. 30-call cap. Do not commit your key.
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini

# --- CodeBuddy Agent SDK (only when AGENT_RUNTIME=codebuddy) -----------------
# No extra install: the SDK (@tencent-ai/agent-sdk) ships its own CLI binary in
# node_modules and spawns it from there. Just `npm install` and set the key.
# Get an API key at:
#   International:  https://www.codebuddy.ai/profile/keys
#   China:          https://copilot.tencent.com/profile/
CODEBUDDY_API_KEY=
# Use `default-model` to follow the account default, or one of:
# gemini-3.1-pro, gemini-2.5-pro, gpt-5.5, deepseek-v3-2-volc, glm-5.0, kimi-k2.5
CODEBUDDY_MODEL=default-model
# Set to "internal" for China edition, "ioa" for iOA. Leave blank for International.
CODEBUDDY_INTERNET_ENVIRONMENT=

# --- HTTP server (when running archetypes as standalone services) ------------
PORT=8080
